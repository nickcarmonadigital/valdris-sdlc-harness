{
  "name": "valdris-sdlc-harness",
  "version": "0.1.0",
  "private": true,
  "description": "Valdris SDLC Harness: commissioning, project adapters, proof gates, and workflow telemetry for Claude Code/Codex/Hermes.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "commission": "node scripts/commission-harness.mjs",
    "commission:questions": "node scripts/commission-harness.mjs --print-questions",
    "simulate:agent": "node scripts/simulate-agent-run.mjs",
    "verify:harness": "node scripts/verify-harness.mjs",
    "graphify:scan": "node scripts/graphify-scan.mjs",
    "graphify:gate": "node scripts/graphify-gate.mjs && node scripts/anchor-gate.mjs",
    "bridge:claude": "node scripts/claude-code-bridge.mjs",
    "bridge:emit": "node scripts/uash-emit-event.mjs"
  },
  "dependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "next": "latest",
    "react": "latest",
    "react-dom": "latest",
    "typescript": "latest"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
